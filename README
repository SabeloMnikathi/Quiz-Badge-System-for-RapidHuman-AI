    App --> AdminPage["AdminPage<br/>Password gate + CRUD"]
    App --> NotFound["NotFoundPage"]

    QuizPage --> QuestionCard["QuestionCard<br/>Radio options + animation"]
    QuizPage --> Timer["Timer<br/>Per-question countdown"]
    QuizPage --> ProgressBar["ProgressBar<br/>Step indicator"]
    QuizPage --> QuizContext["QuizContext<br/>useReducer state"]

    ResultPage --> BadgeScreen["BadgeScreen<br/>Confetti + badge"]
    AdminPage --> AdminQuestionForm["AdminQuestionForm<br/>Add / edit question"]

    subgraph Services["services/ (all Supabase calls)"]
        supabase["supabase.ts<br/>client init"]
        questionsService["questionsService.ts"]
        attemptsService["attemptsService.ts"]
        badgesService["badgesService.ts"]
    end

    subgraph Hooks["hooks/"]
        useQuestions["useQuestions.ts"]
        useTimer["useTimer.ts"]
        useQuizSession["useQuizSession.ts"]
    end

    QuizPage --> useQuestions
    QuizPage --> useTimer
    QuizPage --> useQuizSession
    useQuestions --> questionsService
    attemptsService --> supabase
    questionsService --> supabase
    badgesService --> supabase
```

